# Copy this file to .streamlit/secrets.toml (same folder) and fill in real values.
# Locally: Streamlit reads app/.streamlit/secrets.toml automatically.
# On Streamlit Community Cloud: paste the same contents into
#   your app -> Settings -> Secrets  (don't commit your real secrets.toml to GitHub)

[smtp]
host = "smtp.gmail.com"
port = 587
user = "youraccount@gmail.com"
password = "your-16-char-app-password"   # NOT your normal Gmail password — see note below
from_email = "youraccount@gmail.com"

# --- Gmail note ---
# Gmail blocks plain password SMTP login. You need an "App Password":
# 1. Turn on 2-Step Verification on the Google account: https://myaccount.google.com/security
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Generate an app password for "Mail", paste the 16-character result above as `password`.
#
# Any other SMTP provider works too (SendGrid, Mailgun, Amazon SES, your own mail server) —
# just fill in its host/port/user/password.
